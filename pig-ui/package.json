{
  "name": "pig-ui",
  "version": "3.9.2",
  "description": "pig 前端项目 - Vite + Vue3 + TypeScript + Pinia + Element Plus",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss}\""
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "pinia-plugin-persistedstate": "^3.2.0",
    "element-plus": "^2.8.0",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.0",
    "nprogress": "^0.2.0",
    "screenfull": "^6.0.2",
    "dayjs": "^1.11.0",
    "js-cookie": "^3.0.5",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^7.0.0"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/runtime-core": "^3.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "sass": "^1.77.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^2.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
